{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "_pandacorp": "Canonical knip config (DR-059) for the Next.js stack. Installed VERBATIM by /pandacorp:blueprint; re-synced + conformance-checked by /pandacorp:upgrade. Fail-closed dead-code gate wired into verify.sh.",
  "entry": [
    "src/app/**/{page,layout,loading,error,not-found,global-error,route,template,default}.{ts,tsx}",
    "src/app/**/{sitemap,robots,manifest,opengraph-image,icon,apple-icon}.{ts,tsx}",
    "src/middleware.ts",
    "src/instrumentation.ts",
    "next.config.{js,mjs,ts}",
    "e2e/**/*.spec.ts",
    "playwright.config.ts",
    "vitest.config.{ts,mts}"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": ["**/*.d.ts", ".next/**", "src/test/**"],
  "ignoreDependencies": [],
  "next": true,
  "vitest": true,
  "playwright": true
}
