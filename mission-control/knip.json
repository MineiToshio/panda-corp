{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/app/**/{page,layout,loading,error,not-found,global-error,route,template,default}.{ts,tsx}",
    "src/app/**/{sitemap,robots,manifest,opengraph-image,icon,apple-icon}.{ts,tsx}",
    "src/middleware.ts",
    "src/proxy.ts",
    "src/instrumentation.ts",
    "next.config.{js,mjs,ts}",
    "e2e/**/*.spec.ts",
    "playwright.config.ts",
    "vitest.config.{ts,mts}"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": ["**/*.d.ts", ".next/**", "src/test/**"],
  "ignoreDependencies": ["tailwindcss", "@axe-core/playwright"],
  "next": true,
  "vitest": true,
  "playwright": true
}
