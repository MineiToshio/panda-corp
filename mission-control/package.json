{
  "name": "mission-control",
  "version": "0.1.0",
  "private": true,
  "description": "Pandacorp Mission Control — local, read-only factory dashboard (never calls Claude).",
  "type": "module",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1 --port 3000",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --reporter=dot",
    "test:watch": "vitest",
    "test:smoke": "playwright test e2e/smoke.spec.ts",
    "test:visual": "playwright test e2e/visual.spec.ts",
    "test:responsive": "playwright test e2e/responsive.spec.ts",
    "test:shell": "playwright test e2e/shell.spec.ts",
    "verify": "bash .pandacorp/verify.sh",
    "stats:regen": "node --loader ./scripts/read-model/ts-loader.mjs scripts/read-model/regen.mjs",
    "stats:sync-aggregate": "node --loader ./scripts/read-model/ts-loader.mjs scripts/read-model/sync-aggregate.mjs",
    "stats:backfill": "node --loader ./scripts/read-model/ts-loader.mjs scripts/read-model/backfill.mjs",
    "lint:eslint": "eslint .",
    "lint:cycles": "madge --circular --extensions ts,tsx --ts-config tsconfig.json src"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "gray-matter": "^4.0.3",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@biomejs/biome": "^2.5.2",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.18.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.39.4",
    "eslint-plugin-testing-library": "^7.16.2",
    "jsdom": "^26.1.0",
    "knip": "^6.17.1",
    "madge": "^8.0.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "packageManager": "pnpm@10.12.1"
}
