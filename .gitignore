# Obsidian workspace noise
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/plugins/*/data.json
.obsidian/cache
.trash/

# State caches
.pandacorp-cache/

# Owner's personal data (NOT published). The versioned seeds are
# factory/profile.example.md and factory/portfolio.example.md; /pandacorp:onboarding
# generates the real versions below. The idea cards are personal too.
factory/profile.md
factory/portfolio.md
factory/ideas/*.md
!factory/ideas/_idea-template.md
!factory/ideas/decision-log.md
factory/ideas/_drafts/*.md
!factory/ideas/_drafts/README.md

# Mission Control communication layer (Spanish, owner-facing, regenerable). status.yaml stays committed.
mission-control/docs/summary.md
mission-control/docs/activity.md

# OS
.DS_Store

# Claude Code local
.claude/settings.local.json
.claude/launch.json
