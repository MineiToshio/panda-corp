# Obsidian workspace noise
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/plugins/*/data.json
.obsidian/cache
.trash/

# State caches
.pandacorp-cache/
# Factory-root runtime state — LIVE machinery, not stale (audit-20): DR-099's per-session
# touched-file records (.pandacorp/run/sessions/) and worktree manifests (.pandacorp/run/worktrees/)
# actively live here. The factory has no .pandacorp/ OVERLAY (no status.yaml — it is not a product
# project; the DR-062 marker still discriminates), but its runtime dir is real. Never committed.
.pandacorp/

# Node / build artefacts (no package.json at root — any node_modules here is accidental)
node_modules/

# Owner's personal data (NOT published). The versioned seeds are
# factory/profile.example.md and factory/portfolio.example.md; /pandacorp:onboarding
# generates the real versions below. The idea cards are personal too.
factory/profile.md
factory/portfolio.md
factory/ports.yaml
factory/ideas/*.md
!factory/ideas/_idea-template.md
!factory/ideas/decision-log.md
factory/ideas/_drafts/*.md
!factory/ideas/_drafts/README.md

# Mission Control integration layer — gitignored parts (Spanish comms, inbox, runtime). .pandacorp/status.yaml stays committed.
mission-control/.pandacorp/comms/
mission-control/.pandacorp/inbox/
mission-control/.pandacorp/run/

# Factory self-learning raw capture inbox (provisional notes; the librarian refines them into committed factory/memory/LESSON-*.md)
factory/memory/_inbox.md
# Sweep marker written by the scheduled memory routine (machine-local state, loop v2)
factory/memory/_last-sweep

# Gamification ledger — personal data (DR-033, AC-09-006.3). Records the historical
# maximum guild outcomes so deleting a project never decreases XP/level (WO-09-006).
factory/gamification-ledger.json

# OS
.DS_Store

# Claude Code local (any level: root, mission-control/, projects…)
.claude/settings.local.json
.claude/launch.json
**/.claude/settings.local.json
**/.claude/launch.json

# Owner-facing Spanish pitches/memos (HTML) — gitignored per the committed=English rule
docs/proposals/*.html
factory/ideas/*.html
