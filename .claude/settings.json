{
  "permissions": {
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(gh repo delete:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/decision-log-reminder.sh\"",
            "timeout": 10,
            "statusMessage": "Decision log · reminder"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/plugin/scripts/backup-pandacorp-state.sh\" \"$CLAUDE_PROJECT_DIR\"",
            "timeout": 30,
            "statusMessage": "Pandacorp state backup"
          }
        ]
      }
    ]
  }
}
