{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/block-dangerous.sh\"",
            "timeout": 10,
            "statusMessage": "Pandacorp safety gate"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/warn-adhoc-write.sh\"",
            "timeout": 10,
            "statusMessage": "Pandacorp write-gate"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/verify-before-stop.sh\"",
            "timeout": 300,
            "statusMessage": "Pandacorp verify gate"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/emit-event.sh\" SubagentStop"
          }
        ]
      }
    ]
  }
}
