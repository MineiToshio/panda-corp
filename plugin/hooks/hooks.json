{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/backup-pandacorp-state.sh\"",
            "timeout": 30,
            "statusMessage": "Pandacorp state backup"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/rotate-events.sh\"",
            "timeout": 15,
            "statusMessage": "Pandacorp event-log rotation"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/block-dangerous.sh\"",
            "timeout": 10,
            "statusMessage": "Pandacorp safety gate"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/warn-adhoc-write.sh\"",
            "timeout": 10,
            "statusMessage": "Pandacorp write-gate"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/remind-manual-sync.sh\"",
            "timeout": 10,
            "statusMessage": "Pandacorp Manual-sync"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/remind-backport-gate-config.sh\"",
            "timeout": 10,
            "statusMessage": "Pandacorp gate-config back-port"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/verify-before-stop.sh\"",
            "timeout": 300,
            "statusMessage": "Pandacorp verify gate"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/capture-lessons-reminder.sh\"",
            "timeout": 15,
            "statusMessage": "Pandacorp capture check"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/check-derived-drift.sh\"",
            "timeout": 30,
            "statusMessage": "Pandacorp derived-drift gate"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/emit-event.sh\" SubagentStop"
          }
        ]
      }
    ]
  }
}
