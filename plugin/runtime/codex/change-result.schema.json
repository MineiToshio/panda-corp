{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["done", "verdict", "summary", "findings", "change_kind", "affected_frds", "mutations", "reopen_work_orders"],
  "properties": {
    "done": { "type": "boolean" },
    "verdict": { "enum": ["green", "red", "needs-owner", "retry"] },
    "summary": { "type": "string" },
    "findings": { "type": "array", "items": { "type": "string" } },
    "change_kind": { "enum": ["bug", "feature", "change"] },
    "affected_frds": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^frd-[a-z0-9-]+$" } },
    "mutations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target", "content"],
        "properties": {
          "target": { "type": "string" },
          "content": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "reopen_work_orders": { "type": "array", "items": { "type": "string", "pattern": "^WO-[A-Za-z0-9-]+$" } }
  },
  "additionalProperties": false
}
